# Copia este archivo a ".env" y rellena tus valores reales.

# --- Supabase (base de datos) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ============================================================
# PROVEEDORES DE IA  (orden de preferencia: Mistral → DeepSeek → Claude)
# ============================================================

# --- Mistral AI  (primario para texto y Codestral para código) ---
# Obtén tu clave en: https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
CODESTRAL_MODEL=codestral-latest

# --- DeepSeek  (segundo en la cadena de fallback) ---
# Obtén tu clave en: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Claude / Anthropic  (último recurso — OBLIGATORIO como garantía de servicio) ---
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_para_verificar_webhook

# --- Servidor ---
PORT=3000

# Secreto para el cron del motor de seguimiento (invéntate uno largo y aleatorio).
CRON_SECRET=
