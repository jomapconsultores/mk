# Copia este archivo a ".env" y rellena tus valores reales.

# --- Supabase (base de datos) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ============================================================
# PROVEEDORES DE IA  (orden de preferencia: Mistral → DeepSeek → Claude)
# ============================================================

# --- Mistral AI  (primario para texto y Codestral para código) ---
# Obtén tu clave en: https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
CODESTRAL_API_KEY=
CODESTRAL_MODEL=codestral-latest

# --- DeepSeek  (segundo en la cadena de fallback) ---
# Obtén tu clave en: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- Claude / Anthropic  (último recurso — OBLIGATORIO como garantía de servicio) ---
# Obtén tu clave en: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Email saliente (Resend) — para outreach por correo ---
# Obtén tu clave en: https://resend.com/
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# --- Google Places — para scraping de negocios (Captación activa) ---
# Obtén tu clave en: https://console.cloud.google.com/ (API: Places API New)
GOOGLE_PLACES_API_KEY=

# --- WhatsApp Cloud API (Meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=mi_token_secreto_para_verificar_webhook
# Verificación de firma del webhook de WhatsApp (Meta → App → Configuración → Clave secreta de la app)
WHATSAPP_APP_SECRET=

# --- Servidor ---
PORT=3000

# Orígenes permitidos por CORS (separados por coma) — hoy solo lo usa la landing
# (formulario público de /capture); el dashboard ya NO llama al backend directo
# desde el navegador, pasa por su propio proxy server-side (ver INTERNAL_API_SECRET).
# Deja el default si no cambiaste los dominios.
CORS_ORIGINS=https://marketing.pensamiento-libre.org,https://panel.marketing.pensamiento-libre.org

# URLs de las otras 2 apps del proyecto (opcionales — solo para los links en la página raíz "/").
DASHBOARD_URL=https://panel.marketing.pensamiento-libre.org
LANDING_URL=https://marketing.pensamiento-libre.org

# Secreto para el cron del motor de seguimiento y de prospección (invéntate uno largo y aleatorio).
# Protege tanto POST /cron/run-sequences como POST /cron/run-prospecting.
CRON_SECRET=

# Secreto compartido con el proxy server-side del dashboard (dashboard/src/app/api/backend/[...path]/route.ts).
# Protege TODOS los endpoints que cuestan dinero (IA, Twilio) o exponen el CRM
# (captacion/*, prospecting/*, leads/rescore, calls/initiate). Debe ser EXACTAMENTE
# el mismo valor que INTERNAL_API_SECRET en dashboard/.env.example. Invéntate uno
# largo y aleatorio (ej: openssl rand -hex 32) — nunca lo pongas en una variable
# NEXT_PUBLIC_*, o quedaría visible en el navegador.
INTERNAL_API_SECRET=

# --- Twilio — llamadas salientes (Fase 3; src/calls/twilio.ts) ---
# Sin estas, el módulo de llamadas queda inoperante (lanza error solo al intentar
# una llamada, no rompe el arranque).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# URL pública del backend, para que Twilio alcance el TwiML/WebSocket (src/calls/initiate.ts).
PUBLIC_BACKEND_URL=https://api.marketing.pensamiento-libre.org

# Intervalo (ms) del loop del worker de secuencias (src/worker/sequences.ts). Default 60000.
SEQUENCE_INTERVAL_MS=60000

# --- Observabilidad (Sentry) — opcional; vacío = desactivado ---
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
