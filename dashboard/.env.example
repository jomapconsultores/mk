# Copia a ".env.local" y rellena.

# --- URL del backend ---
# BACKEND_URL: usada SOLO server-side, por el proxy autenticado en
# src/app/api/backend/[...path]/route.ts (el navegador llama a /api/backend/*,
# nunca al backend real directo — así el secreto de abajo nunca sale al bundle).
BACKEND_URL=https://api.marketing.pensamiento-libre.org

# Secreto compartido con el backend (debe coincidir EXACTO con
# INTERNAL_API_SECRET en backend/.env.example). Protege /captacion/*,
# /prospecting/*, /leads/rescore y /calls/initiate — nunca lo pongas en una
# variable NEXT_PUBLIC_*.
INTERNAL_API_SECRET=

# --- Supabase (base de datos) --- usadas SOLO en el servidor.
# Debe ser el MISMO proyecto que usa el backend (ver README.md / docs/coolify-deploy.md): pamplfrwwawfgvbzbndk.
SUPABASE_URL=https://pamplfrwwawfgvbzbndk.supabase.co
SUPABASE_SERVICE_KEY=

# --- Landing público ---
# LANDING_URL: a dónde se envía a un visitante SIN sesión que entra a "/".
# Apunta al deploy del landing público (marketing/landing). Si se deja vacío,
# el fallback es /login (NUNCA '/', eso causaría un bucle de redirección).
LANDING_URL=https://marketing.pensamiento-libre.org

# --- Sesión y acceso al panel ---
# Clave simple para entrar al panel (cambia esto por algo tuyo).
DASHBOARD_PASSWORD=cambia-esta-clave
# Cadena aleatoria larga para firmar la cookie de sesión (ej: openssl rand -hex 32).
SESSION_SECRET=

# --- WebAuthn (biometría / passkeys) ---
# Dominio del dashboard sin protocolo (debe coincidir EXACTAMENTE con el dominio real en Coolify)
WEBAUTHN_RP_ID=panel.marketing.pensamiento-libre.org
# Origen completo con protocolo
WEBAUTHN_ORIGIN=https://panel.marketing.pensamiento-libre.org
