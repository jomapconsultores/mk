# Copia a ".env.local" y rellena.

# --- URL del backend ---
# NEXT_PUBLIC_BACKEND_URL se incrusta en el bundle en build-time (en Coolify: Build Variable).
# BACKEND_URL es la misma URL pero usada en runtime, server-side (importador inteligente con IA).
NEXT_PUBLIC_BACKEND_URL=https://tu-backend.tudominio.com
BACKEND_URL=https://tu-backend.tudominio.com

# --- Supabase (base de datos) --- usadas SOLO en el servidor.
SUPABASE_URL=https://yxypbdcryjerestwbhxm.supabase.co
SUPABASE_SERVICE_KEY=

# --- Sesión y acceso al panel ---
# Clave simple para entrar al panel (cambia esto por algo tuyo).
DASHBOARD_PASSWORD=cambia-esta-clave
# Cadena aleatoria larga para firmar la cookie de sesión (ej: openssl rand -hex 32).
SESSION_SECRET=

# --- WebAuthn (biometría / passkeys) ---
# Dominio del dashboard sin protocolo (debe coincidir EXACTAMENTE con el dominio real en Coolify)
WEBAUTHN_RP_ID=panel.marketing.pensamiento-libre.org
# Origen completo con protocolo
WEBAUTHN_ORIGIN=https://panel.marketing.pensamiento-libre.org
